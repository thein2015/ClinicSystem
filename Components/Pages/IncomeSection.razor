    private async Task ClientPosSummaryFromApiAsync(string machineKey)
    {
        errorMessage = null;
        string apiUrl = $"https://smartlivingmyanmar.com/{DBController.Dbse}/api/get/ClientPosSummary";
        var payloadObject = new { Keyy = machineKey };

        try
        {
            using HttpClient client = new HttpClient();

            // Serialize using System.Text.Json
            string jsonPayload = JsonSerializer.Serialize(payloadObject);
            HttpContent content = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

            // Execute POST
            HttpResponseMessage response = await client.PostAsync(apiUrl, content);

            if (response.IsSuccessStatusCode)
            {
                string rawJson = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(rawJson)) return;

                // Deserialize using System.Text.Json
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var apiResponse = JsonSerializer.Deserialize<IncomeApiResponse>(rawJson, options);

                if (apiResponse != null && apiResponse.Status == 0 && apiResponse.Result != null)
                {
                    // Assign to component variables (UI updates automatically)
                    sellAmount = apiResponse.Result.Amount;
                    discount = apiResponse.Result.Discount;
                    total = apiResponse.Result.Total;
                    grandTotal = apiResponse.Result.GrandTotal;

                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Client POS Sync Error: {ex.Message}";
            Console.WriteLine(errorMessage);
        }
    }
    private async Task FetchTreatmentSummaryFromApiAsync(string machineKey)
    {
        // Point to your POST endpoint
        string apiUrl = $"https://smartlivingmyanmar.com/{DBController.Dbse}/api/get/TreatmentSummary";

        // Build the payload
        var payloadObject = new { Keyy = machineKey };

        try
        {
            using HttpClient client = new HttpClient();

            // Serialize using System.Text.Json
            string jsonPayload = JsonSerializer.Serialize(payloadObject);
            HttpContent content = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

            // Execute POST
            HttpResponseMessage response = await client.PostAsync(apiUrl, content);

            if (response.IsSuccessStatusCode)
            {
                string rawJson = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(rawJson)) return;

                // Deserialize using System.Text.Json
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var apiResponse = JsonSerializer.Deserialize<IncomeApiResponse>(rawJson, options);

                if (apiResponse != null && apiResponse.Status == 0 && apiResponse.Result != null)
                {
                    // Blazor automatically handles UI updates—no need for MainThread.BeginInvokeOnMainThread
                    sellAmount = apiResponse.Result.Amount;
                    discount = apiResponse.Result.Discount;
                    total = apiResponse.Result.Total;
                    grandTotal = apiResponse.Result.GrandTotal;

                    // Notify Blazor to refresh the UI
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            // Use console logging for web
            Console.WriteLine($"Treatment Sync Error: {ex.Message}");
        }
    }

    private async Task FetchIncomeSummaryFromApiAsyncCall() => await FetchIncomeSummaryFromApiAsync(DBController.Keyy);

    // 1. Remove: using Newtonsoft.Json;
    // 2. Add: using System.Text.Json;

    private async Task FetchIncomeSummaryFromApiAsync(string machineKey)
    {
        errorMessage = null;
        string apiUrl = $"https://smartlivingmyanmar.com/{DBController.Dbse}/api/get/IncomeSummary/{machineKey}";

        try
        {
            using HttpClient client = new HttpClient();
            var response = await client.GetAsync(apiUrl);
            response.EnsureSuccessStatusCode();

            string rawJson = await response.Content.ReadAsStringAsync();

            // Use System.Text.Json instead of Newtonsoft
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var apiResponse = JsonSerializer.Deserialize<IncomeApiResponse>(rawJson, options);

            if (apiResponse?.Status == 0 && apiResponse.Result != null)
            {
                sellAmount = apiResponse.Result.Amount;
                discount = apiResponse.Result.Discount;
                total = apiResponse.Result.Total;
                grandTotal = apiResponse.Result.GrandTotal;
            }
            else { errorMessage = apiResponse?.Msg ?? "Failed to load data."; }
        }
        catch (Exception ex)
        {
            errorMessage = $"Network Error: {ex.Message}";
        }
        StateHasChanged();
    }
}