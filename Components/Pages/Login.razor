        Console.WriteLine($"Key: {key}, DbInfo: {dbInfo}");

        if (string.IsNullOrEmpty(key) || string.IsNullOrEmpty(dbInfo))
        {
            isRegisterMode = true;
        }
        else
        {
            DBController.Keyy = key;
            DBController.Dbse = dbInfo;
            isRegisterMode = false;
        }
    }
     
