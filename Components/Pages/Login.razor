    private async Task OTPconfirm()
    {
        string jsonResult = await VerifyOTP(registerPhone, "Clinic", regOtp);

        if (string.IsNullOrEmpty(jsonResult))
        {
            errorMessage = "Connection error.";
            return;
        }

        // System.Text.Json ဖြင့် Deserialize လုပ်ခြင်း
        using (JsonDocument doc = JsonDocument.Parse(jsonResult))
        {
            JsonElement root = doc.RootElement;

            // status ကို စစ်ဆေးခြင်း
            if (root.TryGetProperty("status", out JsonElement status) && status.GetInt32() == 1)
            {
                // data object အတွင်းမှ key နှင့် dbInfo ကို ထုတ်ယူခြင်း
                JsonElement data = root.GetProperty("data");
                string key = data.GetProperty("Keyy").GetString();
                string dbInfo = data.GetProperty("DbInfo").GetString();

                await UpdateOTP("", registerPhone, "Clinic");
                await ProtectedLocalStore.SetAsync("KInf", key);
                await ProtectedLocalStore.SetAsync("DbInfo", dbInfo);

                isRegisterMode = false;
                errorMessage = "Registered successfully!";
            }
            else
            {
                errorMessage = "Invalid OTP.";
            }
        }
    }
    private async Task HandleLogin() => Nav.NavigateTo("/main-dashboard");

    public string GenerateOTPLogin(int length)
    {
        string _allowedChars = "0123456789";
        var randNum = new Random();
        var chars = new char[length];
        for (int i = 0; i < length; i++)
            chars[i] = _allowedChars[randNum.Next(0, _allowedChars.Length)];
        return new string(chars);
    }


    public async Task<string?> UpdateOTP(string otp, string ownerPh, string typeName)
    {
        using (HttpClient client = new HttpClient())
        {
            client.Timeout = TimeSpan.FromSeconds(15);
            var url = "https://smartlivingmyanmar.com/Ctrl/api/set/SetOTP";

            var requestData = new
            {
                OTP = otp,
                OwnerPh = ownerPh,
                TypeName = typeName
            };

            try
            {
                // System.Text.Json ဖြင့် Serialize လုပ်ခြင်း
                string json = JsonSerializer.Serialize(requestData);

                // Argument အမှားမဖြစ်အောင် သေချာစွာ ထည့်သွင်းခြင်း
                var content = new StringContent(json, Encoding.UTF8, "application/json");

                var response = await client.PostAsync(url, content);
                response.EnsureSuccessStatusCode();

                return await response.Content.ReadAsStringAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
                return null;
            }
        }
    }
    private async Task GetOtpProcess()
    {
        if (string.IsNullOrWhiteSpace(registerPhone))
        {
            errorMessage = "Please enter your phone number.";
            return;
        }

        otpNo = GenerateOTPLogin(6);
        var vv = await UpdateOTP(otpNo, registerPhone, "Clinic");

        if (vv != null)
        {
            errorMessage = "OTP Request successful. Check with authority.";
        }
    }
