@inject NavigationManager Nav
@inject ClinicSystem.Web.Components.APIService Api
@* @inject ProtectedSessionStorage ProtectedSessionStore *@
@inject ProtectedLocalStorage ProtectedLocalStore
<div class="container mt-5">
    <div class="card p-4 mx-auto shadow" style="max-width: 400px; border-radius: 16px;">

        @* Error Message ပြသသည့်နေရာ *@
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-info">@errorMessage</div>
        }

        @if (isRegisterMode)
        {
            <h3 class="text-center fw-bold mb-2">Device Register</h3>
            <p class="text-center text-muted small mb-4">Verify your phone number with OTP</p>

            <div class="mb-3">
                <input @bind="registerPhone" class="form-control" placeholder="Register Phone" type="tel" />
            </div>

            <button class="btn btn-secondary w-100 mb-3" @onclick="OnRequestOtpClicked">Request OTP</button>

            <div class="mb-4">
                <input @bind="regOtp" class="form-control" placeholder="Enter 6-Digit OTP" maxlength="6" />
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <button class="btn btn-outline-secondary w-100 rounded-pill" @onclick="() => isRegisterMode = false">Cancel</button>
                </div>
                <div class="col-6">
                    <button class="btn btn-primary w-100 rounded-pill" @onclick="OnSaveRegisterClicked">Save</button>
                </div>
            </div>
        }
        else
        {
            <h3 class="text-center fw-bold mb-4">Login</h3>

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input @bind="username" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" @bind="password" class="form-control" />
            </div>

            <button class="btn btn-primary w-100" @onclick="HandleLogin">Login</button>
            <p class="text-center mt-3 text-muted" style="cursor:pointer;" @onclick="() => isRegisterMode = true">
                Need to register device?
            </p>
        }
    </div>
</div>

