    private async Task<string> VerifyOTP(string ownerPh, string typeName, string otp)
    {
        using (var client = new HttpClient())
        {
            string url = $"https://smartlivingmyanmar.com/Ctrl/api/get/verifyOTP?OwnerPh={Uri.EscapeDataString(ownerPh)}&TypeName={Uri.EscapeDataString(typeName)}&OTP={Uri.EscapeDataString(otp)}";
            var response = await client.GetAsync(url);
            return await response.Content.ReadAsStringAsync();
        }
    }
