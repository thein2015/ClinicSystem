@page "/patient-search-list"
@rendermode InteractiveServer
@using System.Text
@using System.Text.Json
@using ClinicSystem.Web.Models
@using ClinicSystem.Web.Controller
@inject DBController DbService
@inject NavigationManager Navigation

<div class="container mt-4">
    <h3 class="mb-4 text-dark font-weight-bold">🔍 Search Patients by Name</h3>

    <div class="mb-4">
        <div class="input-group">
            <span class="input-group-text bg-primary text-white">🔍</span>
            <input type="text" class="form-control form-control-lg border-primary"
                   placeholder="Enter patient name to search..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @bind:after="OnSearchInputChanged" />
        </div>

        @if (isLoading)
        {
            <div class="mt-2 text-primary d-flex align-items-center">
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Searching from Cloud Server...</span>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(uiErrorMessage))
    {
        <div class="alert alert-danger">@uiErrorMessage</div>
    }

    @if (filteredPatients != null && filteredPatients.Any())
    {
        <div class="row">
            @foreach (var patient in filteredPatients)
            {
                <div class="col-md-12 mb-3">
                    <div class="card shadow-sm" style="border-left: 5px solid #28a745;">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="text-success font-weight-bold mb-1">@patient.PatientName</h5>
                                <p class="mb-1 text-secondary" style="font-size: 0.9rem;">
                                    <strong>📞 Phone:</strong> @(string.IsNullOrEmpty(patient.Telephone) ? "N/A" : patient.Telephone) |
                                    <strong>🏠 Address:</strong> @(string.IsNullOrEmpty(patient.Address) ? "N/A" : patient.Address)
                                </p>
                            </div>
                            <button type="button"
                                    class="btn btn-outline-success btn-sm px-3"
                                    @onclick="() => ViewHistory(patient.PatientId)">
                                History ➡️
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string searchQuery = "";
    private bool isLoading = false;
    private string uiErrorMessage = "";
    private List<PatientNameRecord> filteredPatients = new();
    
    private CancellationTokenSource? cts;

    private async Task OnSearchInputChanged()
    {
        cts?.Cancel();
        cts = new CancellationTokenSource();
        var token = cts.Token;

        try
        {
            await Task.Delay(400, token);
            if (string.IsNullOrWhiteSpace(searchQuery))
            {
                filteredPatients.Clear();
                return;
            }

            await ExecuteSearchCloudAPI(searchQuery, token);
        }
        catch (TaskCanceledException) { /* Expected behavior for debouncing */ }
    }

    private async Task ExecuteSearchCloudAPI(string searchText, CancellationToken token)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            if (DBController.masterPatientList.Count == 0)
            {
                using var client = new HttpClient();
                string url = "https://smartlivingmyanmar.com/CtlClinic1/api/get/GetAllPatientsByKey";
                var response = await client.PostAsJsonAsync(url, new { Keyy = DBController.Keyy }, token);

                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<PatientApiResponse>(cancellationToken: token);
                    DBController.masterPatientList = result?.Data ?? new();
                }
            }

            filteredPatients = DBController.masterPatientList
                .Where(p => p.PatientName != null && p.PatientName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .Take(5)
                .ToList();
        }
        catch (OperationCanceledException)
        {
            // Gracefully handle cancellation
        }
        catch (Exception ex)
        {
            uiErrorMessage = "An error occurred while searching: " + ex.Message;
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    private void ViewHistory(int? patientId)
    {
        if (patientId.HasValue)
        {
            Navigation.NavigateTo($"/patient-history/{patientId.Value}");
        }
    }
}