@page "/report"
@using System.Net.Http.Json
@using ClinicSystem.Web.Controller
@using System.Text.Json
@inject HttpClient Http

<div class="vstack gap-3" style="max-width: 800px;">
    @* ... (Your existing HTML code here) ... *@
</div>

@code {
    private bool isInventory;
    private string selectedFilter = "All";
    private DateTime fromDate = DateTime.Today;
    private DateTime toDate = DateTime.Today;
    private TimeOnly fromTime = new TimeOnly(05, 0, 0);
    private TimeOnly toTime = new TimeOnly(23, 59, 0);

    // Variables for your results
    private double amount, discount, total, grandTotal;

    // MARKED AS async Task
    private async Task Search()
    {
        try
        {
            var payload = new
            {
                Category = selectedFilter,
                StartTime = fromDate.Add(fromTime.ToTimeSpan()).ToString("yyyy-MM-dd HH:mm:ss"),
                EndTime = toDate.Add(toTime.ToTimeSpan()).ToString("yyyy-MM-dd HH:mm:ss"),
                Keyy = "RegK_4"
            };

            string endpoint = isInventory ? "InventoryReport" : "IncomeReport";
            string apiUrl = $"https://smartlivingmyanmar.com/{DBController.Dbse}/api/get/{endpoint}";

            var response = await Http.PostAsJsonAsync(apiUrl, payload);

            if (response.IsSuccessStatusCode)
            {
                // Using JsonElement is the safest way to read dynamic JSON in Blazor
                var data = await response.Content.ReadFromJsonAsync<JsonElement>();

                if (data.GetProperty("status").GetInt32() == 0)
                {
                    var result = data.GetProperty("result");
                    amount = result.GetProperty("Amount").GetDouble();
                    discount = result.GetProperty("Discount").GetDouble();
                    total = result.GetProperty("Total").GetDouble();
                    grandTotal = result.GetProperty("GrandTotal").GetDouble();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}